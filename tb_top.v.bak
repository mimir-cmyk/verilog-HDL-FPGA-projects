`timescale 1ns/1ps

module tb_top;

reg clk;
reg rst;
reg en;
wire [7:0] data_out;

top_system uut (
    .clk(clk),
    .rst(rst),
    .en(en),
    .data_out(data_out)
);

// Clock generation
always #5 clk = ~clk;

initial begin
    clk = 0;
    rst = 1;
    en = 0;

    // Reset test
    #10 rst = 0;

    // Enable counting
    #10 en = 1;

    // Let it run
    #100;

    // Disable (hold test)
    en = 0;
    #40;

    // Enable again
    en = 1;
    #60;

    $stop;
end

endmodule
