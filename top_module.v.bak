module top_module (
    input wire clk,
    input wire rst,
    input wire en,
    output wire [7:0] data_out
);

wire [2:0] addr;
wire [7:0] rom_data;

// Counter
counter c1 (
    .clk(clk),
    .rst(rst),
    .en(en),
    .count(addr)
);

// ROM
rom r1 (
    .addr(addr),
    .data(rom_data)
);

// Register
reg8 r2 (
    .clk(clk),
    .rst(rst),
    .en(en),
    .d(rom_data),
    .q(data_out)
);

endmodule
